# AI News Digest - Environment Configuration
# Copy this file to .env and add your actual values

# Required: Fireworks AI API Key for LLM analysis
# Get yours at: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Recommended: Stable secret key for Flask sessions
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-string
